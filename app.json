{
  "expo": {
    "name": "Tappy Word",
    "slug": "tappy-word",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f2e"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.sammorrison.tappyword",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-7289760521218684~9372375010",
          "iosAppId": "ca-app-pub-7289760521218684~1657536521"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8449672c-5804-457f-8203-702ba1dd8c05"
      }
    }
  }
}
